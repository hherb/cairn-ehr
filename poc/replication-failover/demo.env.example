# ---------------------------------------------------------------------------
# Two-machine demo configuration.
#
# Copy this to `demo.env` on EACH machine and edit the few values marked below.
# When `demo.env` exists, the CLI runs in two-machine mode: this host runs ONE
# node and reaches the other across the network.
#
#   cp demo.env.example demo.env   # then edit
#
# The two machines' files are mirror images of each other. The shared secret
# (CAIRN_DB_PASSWORD) MUST be identical on both.
# ---------------------------------------------------------------------------

# ===== THIS machine's node =====
CAIRN_SELF_NAME=A          # <-- "A" on machine A, "B" on machine B
CAIRN_SELF_PORT=55432      # local PostgreSQL port (same value on both is fine)

# ===== The OTHER machine (the peer) =====
CAIRN_PEER_NAME=B          # <-- "B" on machine A, "A" on machine B
CAIRN_PEER_HOST=10.0.0.2   # <-- the peer's IP address (see `bin/netcheck.sh`)
CAIRN_PEER_PORT=55432      # the peer's PostgreSQL port

# ===== Shared database identity (IDENTICAL on both machines) =====
CAIRN_DB_NAME=cairn
CAIRN_DB_USER=cairn_demo
CAIRN_DB_PASSWORD=change-me-to-a-shared-secret   # <-- same string on both

# ===== Networking knobs (defaults are fine for an isolated demo LAN) =====
# Which addresses PostgreSQL listens on. '*' = all interfaces.
CAIRN_LISTEN=*
# Which clients may connect over TCP with a password. 'samenet' = any subnet
# this machine is directly attached to (works for a direct Ethernet cable or a
# shared switch without hardcoding an IP range). Override with a CIDR if you
# prefer, e.g. 192.168.1.0/24.
CAIRN_ALLOW_CIDR=samenet
